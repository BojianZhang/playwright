{
  "name": "DreaminaCredentialStage",
  "fields": {
    "email": {
      "required": true,
      "selectors": [
        "input[role='textbox']",
        "input[type='email']",
        "input[placeholder*='email' i]",
        "input[aria-label*='email' i]",
        "input[name*='email' i]",
        "input[autocomplete='username']",
        "input[autocomplete='email']",
        "input:not([type='password'])"
      ]
    },
    "password": {
      "required": true,
      "selectors": [
        "input[type='password']"
      ]
    }
  },
  "submit": {
    "texts": [
      "Continue"
    ],
    "selectors": [
      "button"
    ]
  },
  "successSignals": {
    "texts": [
      "Resend code"
    ],
    "selectors": [
      "input[maxlength='6']",
      "input[autocomplete='one-time-code']"
    ]
  },
  "failureSignals": {
    "existingAccount": [
      "An account with this email already exists",
      "Enter your password to sign in to your account"
    ],
    "rejected": [
      "Couldn't sign up. Try again later.",
      "Try again later"
    ],
    "rateLimited": [
      "Too many attempts",
      "Try again later"
    ],
    "inlineErrors": [
      "error",
      "warning"
    ]
  }
}
