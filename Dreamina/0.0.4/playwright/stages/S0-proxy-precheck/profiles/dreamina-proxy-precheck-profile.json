{
  "site": "dreamina",
  "chain": "proxy-precheck",
  "targets": {
    "primary": {
      "url": "https://www.dreamina.com/",
      "method": "GET",
      "okMinStatus": 200,
      "okMaxStatus": 399,
      "timeoutMs": 15000
    },
    "secondary": {
      "url": "https://www.capcut.com/",
      "method": "GET",
      "okMinStatus": 200,
      "okMaxStatus": 399,
      "timeoutMs": 15000
    },
    "exitIp": {
      "url": "https://api.ipify.org?format=json",
      "method": "GET",
      "timeoutMs": 15000
    }
  },
  "homepageShell": {
    "url": "https://www.dreamina.com/",
    "method": "GET",
    "timeoutMs": 15000,
    "minBodyTextLength": 120,
    "titlePatterns": [
      "Dreamina",
      "CapCut"
    ],
    "shellTexts": [
      "Explore Create Assets",
      "Start Creating With AI Agent",
      "AI Image",
      "Canvas",
      "Create realistic talk"
    ],
    "errorTexts": [
      "Something went wrong",
      "Refresh the page and try again",
      "Access denied",
      "Too many requests"
    ]
  },
  "loginAffordance": {
    "texts": [
      "Sign in",
      "Log in",
      "Login",
      "Continue with email",
      "Sign up"
    ],
    "selectorHints": [
      "SiderMenuLogin",
      "continue with email",
      "sign in"
    ],
    "minAffordanceCount": 1
  }
}

