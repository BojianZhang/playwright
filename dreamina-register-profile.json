{
  "homeUrl": "https://dreamina.capcut.com/ai-tool/home",
  "loginSignals": {
    "emailInputRoleName": "Enter email",
    "continueWithEmailText": "Continue with email",
    "entryTexts": ["Sign in", "Log in", "Login", "Sign up"],
    "entryRolePattern": "sign in|log in|login|sign up"
  },
  "signupForm": {
    "emailInputRoleName": "Enter email",
    "passwordInputRoleName": "Enter password",
    "continueButtonRoleName": "Continue",
    "signUpText": "Sign up"
  },
  "verification": {
    "countdownPatterns": [
      "Resend code in\\s*\\d+s",
      "resend code"
    ],
    "countdownClassSelectors": [
      "[class*='count'][class*='down']",
      "[class*='code-count']"
    ],
    "inputSelectors": [
      "input[maxlength='6'][autocomplete='one-time-code']",
      "input[autocomplete='one-time-code'][inputmode='numeric']",
      ".verification_code_input-wrapper input[maxlength='6']",
      ".verification_code_input-wrapper",
      "[class*='verification_code_input-wrapper']",
      ".verification_code_input-number-focus",
      "[class*='verification_code_input-number-focus']"
    ],
    "wrongCodePatterns": [
      "Wrong verification code\\. Try again\\."
    ]
  },
  "birthday": {
    "yearInputRoleName": "Year",
    "monthText": "Month",
    "dayText": "Day",
    "nextButtonSelector": "button.lv_new_sign_in_panel_wide-birthday-next"
  },
  "overlays": {
    "buttonNames": [
      "Accept all",
      "Accept",
      "I agree",
      "Got it",
      "Close",
      "Skip",
      "Not now",
      "Maybe later"
    ],
    "buttonNamePattern": "accept all|accept|i agree|got it|close|skip|not now|maybe later",
    "extraSelectors": [
      "button[aria-label='Close']",
      "[data-testid='close']",
      "svg[aria-label='Close']"
    ]
  },
  "postRegisterReady": {
    "selectors": [
      "[class*='credit-display-container']"
    ],
    "texts": [
      "You haven't subscribed yet",
      "Subscribe",
      "Start Creating With AI Agent",
      "Canvas",
      "AI Image"
    ]
  },
  "firstLoadHealth": {
    "runGraceWaitMs": 4000,
    "testGraceWaitMs": 12000,
    "graceWaitMs": 12000,
    "validTextSignals": [
      "Continue with email",
      "Sign in",
      "Log in",
      "Login",
      "Sign up",
      "Create realistic talk",
      "Start Creating With AI Agent",
      "AI Image",
      "Canvas"
    ],
    "validSelectors": [
      "input[role='textbox']",
      "button",
      "a",
      "[class*='credit-display-container']"
    ]
  },
  "existingAccountSignals": {
    "patterns": [
      "An account with this email already exists",
      "An account with this email already exists\\. Enter your password to sign in to your account\\.",
      "Enter your password to sign in to your account"
    ],
    "signInHints": [
      "sign in to your account",
      "Enter your password to sign in"
    ]
  },
  "signupFailureRules": [
    {
      "reason": "ACCOUNT_ALREADY_EXISTS",
      "label": "邮箱已存在",
      "pattern": "An account with this email already exists"
    },
    {
      "reason": "ACCOUNT_ALREADY_EXISTS",
      "label": "邮箱已存在：进入登录提示",
      "pattern": "Enter your password to sign in to your account"
    },
    {
      "reason": "SIGNUP_REJECTED",
      "label": "注册失败：稍后重试",
      "pattern": "Couldn't sign up\\. Try again later\\."
    },
    {
      "reason": "SIGNUP_REJECTED",
      "label": "注册失败：请稍后重试",
      "pattern": "Try again later"
    },
    {
      "reason": "SIGNUP_REJECTED",
      "label": "注册失败：页面异常",
      "pattern": "Something went wrong"
    },
    {
      "reason": "SIGNUP_REJECTED",
      "label": "注册失败：尝试过多",
      "pattern": "Too many attempts"
    },
    {
      "reason": "VERIFICATION_CODE_RATE_LIMITED",
      "label": "验证码发送过多，稍后再试",
      "pattern": "Verification code has been sent too many times\\. Try again later\\."
    }
  ]
}
